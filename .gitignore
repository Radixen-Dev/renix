# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Secrets — NEVER commit
.env

# Runtime data — not committed (see data/.gitkeep)
data/*.db
data/*.json
data/*.sqlite

# Log files — not committed (see logs/.gitkeep)
logs/*.log
logs/*.log.*

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Type checking
.mypy_cache/

# Ruff
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Model cache (faster-whisper, openwakeword)
models/
*.bin
*.pt
*.onnx
