# Copy this file to .env and fill in your secret values.
# Never commit the real .env file — it is listed in .gitignore.

# LLM API key — required if your OpenAI-compatible endpoint needs authentication.
# Leave blank for local endpoints (e.g. LM Studio) that don't require auth.
LLM_API_KEY=

# OpenWeatherMap API key — required for the weather tool.
WEATHER_API_KEY=
